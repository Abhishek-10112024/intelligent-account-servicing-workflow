# ── Core ──────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Leave blank to run in mock mode (no internet required)
GEMINI_API_KEY=

# Set to true to disable mock fallback (use for demos / production)
GEMINI_STRICT=false

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: SQLite (auto-created, no setup needed)
DATABASE_URL=sqlite:///./iasw.db

# Docker / Production: PostgreSQL (uncomment and fill in)
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/iasw_db

# ── Redis ─────────────────────────────────────────────────────────────────────
# Optional — system runs without Redis but checker queue won't be cached
REDIS_URL=redis://localhost:6379/0

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Local dev default: http://localhost:5173
# Production: set to your actual deployed frontend URL (e.g. https://iasw.yourbank.com)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Max intake submissions per minute per IP
RATE_LIMIT=10/minute

# ── Confidence Thresholds ─────────────────────────────────────────────────────
APPROVE_THRESHOLD=0.80
FLAG_THRESHOLD=0.60
